<div class="hero min-h-[80vh] bg-base-200">
  <div class="hero-content text-center">
    <div class="max-w-2xl">
      <h1 class="text-5xl font-bold text-primary">Welcome to Quiz App</h1>
      <p class="py-6 text-lg">
        Test your knowledge, challenge yourself, and learn new things with our interactive quizzes.
      </p>
      <div class="flex justify-center gap-4">
        <%= link_to "Get Started", signup_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "Login", login_path, class: "btn btn-ghost btn-lg" %>
      </div>
    </div>
  </div>
</div>

<div class="max-w-6xl mx-auto px-4 py-16">
  <h2 class="text-3xl font-bold text-center mb-12">Features</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
      <div class="card-body items-center text-center">
        <div class="text-5xl">📚</div>
        <h3 class="card-title">Take Quizzes</h3>
        <p>Access a variety of quizzes on different topics and test your knowledge.</p>
      </div>
    </div>
    
    <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
      <div class="card-body items-center text-center">
        <div class="text-5xl">📊</div>
        <h3 class="card-title">Track Progress</h3>
        <p>View your quiz history and see how you're improving over time.</p>
      </div>
    </div>
    
    <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
      <div class="card-body items-center text-center">
        <div class="text-5xl">👑</div>
        <h3 class="card-title">Create Quizzes</h3>
        <p>Administrators can create and manage quizzes for everyone to enjoy.</p>
      </div>
    </div>
  </div>
</div>