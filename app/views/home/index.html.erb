<div class="text-center py-20">
  <h1 class="text-5xl font-bold text-gray-900 mb-4">Welcome to Quiz App</h1>
  <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
    Test your knowledge, challenge yourself, and learn new things with our interactive quizzes.
  </p>
  <div class="space-x-4">
    <%= link_to "Get Started", signup_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-lg transition inline-block" %>
    <%= link_to "Login", login_path, class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3 px-6 rounded-lg transition inline-block" %>
  </div>
</div>

<div class="max-w-6xl mx-auto px-4 py-16">
  <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Features</h2>
  <div class="grid md:grid-cols-3 gap-8">
    <div class="bg-white rounded-lg shadow-lg p-6 text-center">
      <div class="text-4xl mb-4">📚</div>
      <h3 class="text-xl font-semibold mb-2">Take Quizzes</h3>
      <p class="text-gray-600">Access a variety of quizzes on different topics and test your knowledge.</p>
    </div>
    <div class="bg-white rounded-lg shadow-lg p-6 text-center">
      <div class="text-4xl mb-4">📊</div>
      <h3 class="text-xl font-semibold mb-2">Track Progress</h3>
      <p class="text-gray-600">View your quiz history and see how you're improving over time.</p>
    </div>
    <div class="bg-white rounded-lg shadow-lg p-6 text-center">
      <div class="text-4xl mb-4">👑</div>
      <h3 class="text-xl font-semibold mb-2">Create Quizzes</h3>
      <p class="text-gray-600">Administrators can create and manage quizzes for everyone to enjoy.</p>
    </div>
  </div>
</div>