<div class="max-w-6xl mx-auto">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Manage Users</h1>
    <p class="text-gray-500 mt-2">View and manage user accounts</p>
  </div>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>ID</th>
              <th>Email</th>
              <th>Role</th>
              <th>Quizzes Taken</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td>#<%= user.id %></td>
                <td><%= user.email %></td>
                <td>
                  <span class="badge <%= user.is_admin? ? 'badge-warning' : 'badge-ghost' %>">
                    <%= user.is_admin? ? 'Administrator' : 'Regular User' %>
                  </span>
                </td>
                <td><%#= user.quiz_attempts.count %>Need to fix</td>
                <td><%= time_ago_in_words(user.created_at) %> ago</td>
                <td>
                    <%= link_to toggle_admin_admin_user_path(user),
                            data: {
                              turbo_method: :patch,
                              turbo_confirm: "Are you sure you want to change this user's admin status?"
                            },
                            class: "btn btn-sm #{user.is_admin? ? 'btn-error' : 'btn-success'}" do %>
                      <%= user.is_admin? ? 'Remove Admin' : 'Make Admin' %>
                    <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-center">
    <%= paginate @users %>
  </div>
</div>
