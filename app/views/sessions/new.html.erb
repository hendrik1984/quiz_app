<div class="max-w-md mx-auto mt-10">
  <div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="bg-indigo-600 px-6 py-4">
      <h2 class="text-2xl font-bold text-white">Login</h2>
    </div>
    
    <div class="p-6">
      <%= form_with url: login_path, local: true, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", required: true, placeholder: "Enter your email" %>
        </div>
        
        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", required: true, placeholder: "Enter your password" %>
        </div>
        
        <div>
          <%= f.submit "Login", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-md transition" %>
        </div>
      <% end %>
      
      <div class="mt-4 text-center">
        <p class="text-sm text-gray-600">Don't have an account? <%= link_to "Sign up here", signup_path, class: "text-indigo-600 hover:text-indigo-500 font-medium" %></p>
      </div>
    </div>
  </div>
</div>