<div class="hero min-h-[70vh] bg-base-200">
  <div class="hero-content flex-col lg:flex-row-reverse w-full max-w-md">
    <div class="card w-full shadow-2xl bg-base-100">
      <div class="card-body">
        <h2 class="card-title text-2xl justify-center">Login 🔐</h2>
        <p class="text-center text-gray-500">Welcome back! Please login to your account</p>
        
        <%= form_with url: login_path, local: true, class: "space-y-4 mt-4" do |f| %>
          <div class="form-control">
            <%= f.label :email, class: "label" do %>
              <span class="label-text">Email</span>
            <% end %>
            <%= f.email_field :email, class: "input input-bordered w-full", required: true, placeholder: "Enter your email" %>
          </div>
          
          <div class="form-control">
            <%= f.label :password, class: "label" do %>
              <span class="label-text">Password</span>
            <% end %>
            <%= f.password_field :password, class: "input input-bordered w-full", required: true, placeholder: "Enter your password" %>
          </div>
          
          <div class="form-control mt-6">
            <%= f.submit "Login", class: "btn btn-primary w-full" %>
          </div>
        <% end %>
        
        <div class="divider">or</div>
        <p class="text-center text-sm">
          Don't have an account? 
          <%= link_to "Sign up here", signup_path, class: "link link-primary" %>
        </p>
      </div>
    </div>
  </div>
</div>