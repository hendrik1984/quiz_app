<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Back to Quizzes", quizzes_path, class: "link link-primary" %>
  </div>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h1 class="card-title text-3xl"><%= @quiz.title %></h1>

      <p class="text-gray-600 text-lg mt-2"><%= @quiz.description || "No description provided." %></p>

      <div class="divider"></div>

      <div class="grid grid-cols-2 gap-4 my-4">
        <div class="stats shadow">
          <div class="stat place-items-center">
            <div class="stat-title">Questions</div>
            <div class="stat-value text-primary"><%= @quiz.question_count %></div>
          </div>
        </div>
        <div class="stats shadow">
          <div class="stat place-items-center">
            <div class="stat-title">Total Points</div>
            <div class="stat-value text-secondary"><%= @quiz.total_points %></div>
          </div>
        </div>
      </div>

      <div class="bg-base-200 rounded-lg p-6 mb-4">
        <h3 class="font-semibold text-lg mb-2">Quiz Details</h3>
        <div class="space-y-2">
          <div class="flex justify-between">
            <span class="text-gray-500">Category</span>
            <span class="badge badge-ghost"><%= @quiz.category || "Uncategorized" %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Created by</span>
            <span><%= @quiz.user.email %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Created</span>
            <span><%= time_ago_in_words(@quiz.created_at) %> ago</span>
          </div>
        </div>
      </div>

      <div class="card-actions justify-center mt-4">
        <%= link_to "Start Quiz", "#", class: "btn btn-success btn-lg w-full" %>
      </div>
    </div>
  </div>
</div>
