<div class="max-w-2xl mx-auto">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl">Profile 📸</h2>
      <p class="text-gray-500">Your account information</p>
      
      <div class="divider"></div>
      
      <div class="space-y-4">
        <div class="flex justify-between items-center p-3 bg-base-200 rounded-lg">
          <span class="font-medium">📧 Email</span>
          <span class="text-gray-900"><%= @user.email %></span>
        </div>
        
        <div class="flex justify-between items-center p-3 bg-base-200 rounded-lg">
          <span class="font-medium">👤 Account Type</span>
          <span class="badge <%= @user.is_admin? ? 'badge-warning' : 'badge-ghost' %> badge-lg">
            <%= @user.is_admin? ? '👑 Administrator' : '📝 Regular User' %>
          </span>
        </div>
        
        <div class="flex justify-between items-center p-3 bg-base-200 rounded-lg">
          <span class="font-medium">📅 Member Since</span>
          <span class="text-gray-900"><%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>
      </div>
      
      <div class="card-actions justify-end mt-6">
        <% if current_user == @user || admin? %>
          <%= link_to "✏️ Edit Profile", edit_user_path(@user), class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>