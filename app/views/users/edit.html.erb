<div class="max-w-md mx-auto mt-10">
  <div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="bg-indigo-600 px-6 py-4">
      <h2 class="text-2xl font-bold text-white">Edit Profile</h2>
    </div>
    
    <div class="p-6">
      <%= form_with model: @user, local: true, class: "space-y-6" do |f| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 border border-red-400 text-red-700 px-4 py-3 rounded">
            <h5 class="font-bold"><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</h5>
            <ul class="list-disc list-inside mt-2">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", required: true %>
        </div>
        
        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", placeholder: "Leave blank to keep current password" %>
          <p class="text-xs text-gray-500 mt-1">Minimum 6 characters if changing</p>
        </div>
        
        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password_confirmation, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", placeholder: "Confirm new password" %>
        </div>
        
        <div class="flex space-x-4">
          <%= link_to "Cancel", user_path(@user), class: "flex-1 bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded-md transition text-center" %>
          <%= f.submit "Update Profile", class: "flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-md transition" %>
        </div>
      <% end %>
    </div>
  </div>
</div>