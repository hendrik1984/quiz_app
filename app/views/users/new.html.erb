<div class="hero min-h-[80vh] bg-base-200">
  <div class="hero-content flex-col w-full max-w-md">
    <div class="card w-full shadow-2xl bg-base-100">
      <div class="card-body">
        <h2 class="card-title text-2xl justify-center">Create Account ✨</h2>
        <p class="text-center text-gray-500">Join our quiz community today</p>

        <%= form_with model: @user, url: signup_path, local: true, class: "space-y-4 mt-4" do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-error shadow-lg">
              <span>
                <strong><%= pluralize(@user.errors.count, "error") %></strong> prohibited this account from being saved:
                <ul class="list-disc list-inside mt-2">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </span>
            </div>
          <% end %>

          <div class="form-control">
            <%= f.label :email, class: "label" do %>
              <span class="label-text">Email</span>
            <% end %>
            <%= f.email_field :email, class: "input input-bordered w-full", required: true, placeholder: "you@example.com" %>
            <label class="label">
              <span class="label-text-alt text-gray-500">We'll never share your email</span>
            </label>
          </div>

          <div class="form-control">
            <%= f.label :password, class: "label" do %>
              <span class="label-text">Password</span>
            <% end %>
            <%= f.password_field :password, class: "input input-bordered w-full", required: true, placeholder: "Minimum 6 characters" %>
          </div>

          <div class="form-control">
            <%= f.label :password_confirmation, "Confirm Password", class: "label" do %>
              <span class="label-text">Confirm Password</span>
            <% end %>
            <%= f.password_field :password_confirmation, class: "input input-bordered w-full", required: true, placeholder: "Confirm your password" %>
          </div>

          <div class="form-control mt-6">
            <%= f.submit "Create Account", class: "btn btn-primary w-full" %>
          </div>
        <% end %>

        <div class="divider">or</div>
        <p class="text-center text-sm">
          Already have an account?
          <%= link_to "Login here", login_path, class: "link link-primary" %>
        </p>
      </div>
    </div>
  </div>
</div>
