<div class="max-w-md mx-auto mt-10">
  <div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="bg-indigo-600 px-6 py-4">
      <h2 class="text-2xl font-bold text-white">Sign Up</h2>
    </div>
    
    <div class="p-6">
      <%= form_with model: @user, url: signup_path, local: true, class: "space-y-6" do |f| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 border border-red-400 text-red-700 px-4 py-3 rounded">
            <h5 class="font-bold"><%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:</h5>
            <ul class="list-disc list-inside mt-2">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", required: true, placeholder: "Enter your email" %>
          <p class="text-xs text-gray-500 mt-1">We'll never share your email with anyone else.</p>
        </div>
        
        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", required: true, placeholder: "Minimum 6 characters" %>
        </div>
        
        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password_confirmation, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500", required: true, placeholder: "Confirm your password" %>
        </div>
        
        <div>
          <%= f.submit "Create Account", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-md transition" %>
        </div>
      <% end %>
      
      <div class="mt-4 text-center">
        <p class="text-sm text-gray-600">Already have an account? <%= link_to "Login here", login_path, class: "text-indigo-600 hover:text-indigo-500 font-medium" %></p>
      </div>
    </div>
  </div>
</div>